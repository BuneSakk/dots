// This configuration is merged with the default vicinae configuration file, which you can obtain by running the `vicinae config default` command.
// Every item defined in this file takes precedence over the values defined in the default config or any other imported file.
//
// You can make manual edits to this file, however you should keep in mind that this file may be written to by vicinae when a configuration change is made through the GUI.
// When that happens, any custom comments or formatting will be lost.
//
// If you want to maintain a configuration file with your own comments and formatting, you should create a separate file and add it to the 'imports' array.
//
// Learn more about configuration at https://docs.vicinae.com/config

{
   "$schema": "https://vicinae.com/schemas/config.json",
   "close_on_focus_loss": false,
   "pop_to_root_on_close": true,
   "activate_on_single_click": true,
   "escape_key_behavior": "",
   "theme": {
      "dark": {
         "name": "zenwritten-dark"
      }
   },
   "telemetry": {
      "system_info": false
   },
   "launcher_window": {
      "opacity": 0.8,
      "compact_mode": {
         "enabled": false
      }
   },
   "favorites": [],
   "providers": {
      "browser-extension": {
         "enabled": false
      },
      "calculator": {
         "entrypoints": {
            "history": {
               "enabled": false
            },
            "refresh-rates": {
               "enabled": false
            }
         }
      },
      "clipboard": {
         "preferences": {
            "eraseOnStartup": true,
            "ignorePasswords": true,
            "monitoring": true
         }
      },
      "core": {
         "entrypoints": {
            "about": {
               "enabled": false
            },
            "keybind-settings": {
               "enabled": false
            },
            "report-bug": {
               "enabled": false
            },
            "search-emojis": {
               "preferences": {
                  "defaultAction": "paste",
                  "skinTone": "medium-light"
               }
            },
            "sponsor": {
               "enabled": false
            }
         }
      },
      "developer": {
         "enabled": false
      },
      "font": {
         "enabled": false
      },
      "manage-shortcuts": {
         "enabled": false
      },
      "raycast-compat": {
         "enabled": false
      },
      "snippets": {
         "enabled": false
      },
      "system": {
         "entrypoints": {
            "browse-apps": {
               "enabled": true
            },
            "toggle-mute": {
               "enabled": false
            },
            "volume-0": {
               "enabled": false
            },
            "volume-100": {
               "enabled": false
            },
            "volume-25": {
               "enabled": false
            },
            "volume-50": {
               "enabled": false
            },
            "volume-75": {
               "enabled": false
            },
            "volume-down": {
               "enabled": false
            },
            "volume-up": {
               "enabled": false
            }
         }
      },
      "theme": {
         "enabled": false
      }
   }
}